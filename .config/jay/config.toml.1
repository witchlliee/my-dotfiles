
auto-reload = true

keymap.rmlvo = { layout = "br" }

keymap = """
    xkb_keymap {
        xkb_keycodes { include "evdev+aliases(qwerty)" };
        xkb_types    { include "complete"              };
        xkb_compat   { include "complete"              };
        xkb_symbols  { include "pc+us+inet(evdev)"     };
    };
    """

on-graphics-initialized = [
    { type = "exec", exec = "qs -c noctalia-shell" },
    { type = "exec", exec = "wl-tray-bridge" },
]

[env]
ELECTRON_OZONE_PLATFORM_HINT = "wayland"
QT_QPA_PLATFORM = "wayland"
SDL_VIDEODRIVER = "wayland"
CLUTTER_BACKEND = "wayland"
ELM_DISPLAY = "1"

_JAVA_AWT_WM_NONREPARENTING = "1"
AMD_VULKAN_ICD = "RADV"
MESA_SHADER_CACHE_MAX_SIZE = "12G"
PROTON_ENABLE_WAYLAND = "1"
PROTON_DXVK_LOWLATENCY = "1"
DXVK_FRAME_RATE = "177"
DXVK_FRAME_PACE = "low-latency-vrr-180"
WINEDLLOVERRIDES = "dxgi,d3d11,d3d10core,dinput8,ddraw=n,b"
PROTON_LOCAL_SHADER_CACHE = "1"

QT_QPA_PLATFORMTHEME = "qt6ct"
QT_QPA_PLATFORMTHEME_QT6 = "qt6ct"

[actions]
launch-terminal = { type = "exec", exec = "ghostty" }
launch-browser = { type = "exec", exec = "firefox" }
launch-fileManager = { type = "exec", exec = "dolphin" }

[shortcuts]
Super_L-h = "focus-left"
Super_L-j = "focus-down"
Super_L-k = "focus-up"
Super_L-l = "focus-right"

Super_L-shift-h = "move-left"
Super_L-shift-j = "move-down"
Super_L-shift-k = "move-up"
Super_L-shift-l = "move-right"

Super_L-g = "split-horizontal"
Super_L-shift-v = "split-vertical"

Super_L-n = "toggle-split"
Super_L-m = "toggle-mono"
Super_L-shift-f = "toggle-fullscreen"

Super_L-f = "focus-parent"
Super_L-c = "open-control-center"
Super_L-q = "close"
Super_L-v = "toggle-floating"
Super_L-a = { type = "exec", exec = "qs -c noctalia-shell ipc call launcher toggle" }
Super_L-t = "$launch-terminal"
Super_L-e = "$launch-fileManager"
Super_L-b = "$launch-browser
Super_L-p = { type = "exec", exec = "bemenu-run" }
Super_L-shift-e = "quit"
Super_L-shift-r = "reload-config-toml"

Super_L-alt-F1 = { type = "switch-to-vt", num = 1 }
Super_L-alt-F2 = { type = "switch-to-vt", num = 2 }
Super_L-alt-F3 = { type = "switch-to-vt", num = 3 }
